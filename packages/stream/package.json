{
  "name": "@sozai/stream",
  "version": "0.2.0",
  "license": "MIT",
  "description": "Web streams utilities",
  "keywords": [
    "web",
    "stream",
    "transport"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TairuFramework/sozai",
    "directory": "packages/stream"
  },
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": "./lib/index.js"
  },
  "files": [
    "lib/*"
  ],
  "sideEffects": false,
  "scripts": {
    "build:clean": "del lib",
    "build:js": "swc src -d ./lib --config-file ../../node_modules/@kigu/dev/swc.json --strip-leading-paths",
    "build:types": "tsc --emitDeclarationOnly --skipLibCheck",
    "build": "pnpm run build:clean && pnpm run build:js && pnpm run build:types",
    "test:types": "tsc --noEmit -p tsconfig.test.json",
    "test:unit": "vitest run",
    "test": "pnpm run test:types && pnpm run test:unit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@sozai/async": "workspace:^"
  },
  "publishConfig": {
    "access": "public"
  }
}
