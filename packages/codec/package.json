{
  "name": "@sozai/codec",
  "version": "0.1.0",
  "license": "MIT",
  "description": "Codecs and encoding utilities",
  "keywords": [
    "base64",
    "binary"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TairuFramework/sozai",
    "directory": "packages/codec"
  },
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": "./lib/index.js"
  },
  "files": [
    "lib/*"
  ],
  "sideEffects": false,
  "scripts": {
    "build:clean": "del lib",
    "build:js": "swc src -d ./lib --config-file ../../node_modules/@kigu/dev/swc.json --strip-leading-paths",
    "build:types": "tsc --emitDeclarationOnly --skipLibCheck",
    "build": "pnpm run build:clean && pnpm run build:js && pnpm run build:types",
    "test:types": "tsc --noEmit -p tsconfig.test.json",
    "test:unit": "vitest run",
    "test": "pnpm run test:types && pnpm run test:unit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "canonicalize": "catalog:"
  },
  "devDependencies": {
    "uint8arrays": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
