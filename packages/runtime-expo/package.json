{
  "name": "@sozai/runtime-expo",
  "version": "0.2.2",
  "license": "MIT",
  "description": "Expo runtime",
  "keywords": [],
  "repository": {
    "type": "git",
    "url": "https://github.com/TairuFramework/sozai",
    "directory": "packages/runtime-expo"
  },
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": "./lib/index.js"
  },
  "files": [
    "lib/*"
  ],
  "sideEffects": false,
  "scripts": {
    "build:clean": "del lib",
    "build:js": "swc src -d ./lib --config-file ../../node_modules/@kigu/dev/swc.json --strip-leading-paths",
    "build:types": "tsc --emitDeclarationOnly --skipLibCheck",
    "build": "pnpm run build:clean && pnpm run build:js && pnpm run build:types",
    "test:types": "tsc --noEmit --skipLibCheck -p tsconfig.json",
    "test": "pnpm run test:types",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@sozai/runtime": "workspace:^",
    "expo-crypto": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
